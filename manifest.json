{
  "manifest_version": 3,
  "name": "Eclyzer Hub",
  "description": "Quick access to Eclyzer.net, Eclyzer AI, and Eclyzer tools.",
  "version": "1.5.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Eclyzer Hub",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": []
}
